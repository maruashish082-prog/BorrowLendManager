<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/surface_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left Color Stripe -->
        <View
            android:id="@+id/viewStripe"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/borrow_color" />

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Avatar -->
            <TextView
                android:id="@+id/tvAvatar"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/borrow_color"
                android:background="@drawable/bg_avatar"
                android:layout_marginEnd="12dp" />

            <!-- Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- Row 1: Name + Amount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Name"
                        android:textSize="15sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-bold"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tvAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₹0"
                        android:textSize="15sp"
                        android:textColor="@color/borrow_color"
                        android:fontFamily="monospace"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Row 2: Date + Type Badge -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="01 Jan 2024"
                        android:textSize="11sp"
                        android:textColor="@color/text_hint" />

                    <TextView
                        android:id="@+id/tvType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BORROWED"
                        android:textSize="9sp"
                        android:fontFamily="sans-serif-bold"
                        android:paddingHorizontal="7dp"
                        android:paddingVertical="3dp"
                        android:background="@drawable/bg_badge" />
                </LinearLayout>

                <!-- Remarks -->
                <TextView
                    android:id="@+id/tvRemarks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="11sp"
                    android:textColor="@color/text_hint"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:drawablePadding="4dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <ImageButton
                    android:id="@+id/btnEdit"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_edit"
                    android:tint="@color/primary"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Edit" />

                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_delete"
                    android:tint="@color/borrow_color"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Delete" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
